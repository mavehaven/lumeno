            <div class="pdf-kpi-label">Active Forms</div>
            <div class="pdf-kpi-value">${m.totalForms ?? '—'}</div>
            <div class="pdf-kpi-sub">Collecting responses</div>
          </div>
          <div class="pdf-kpi" style="border-left-color:#d97706">
            <div class="pdf-kpi-label">Avg Readiness Score</div>
            <div class="pdf-kpi-value">${m.avgScore ?? '—'}</div>
            <div class="pdf-kpi-sub">Across all assessments</div>
          </div>
          <div class="pdf-kpi" style="border-left-color:#7c3aed">
            <div class="pdf-kpi-label">Organisations</div>
            <div class="pdf-kpi-value">${m.totalOrgs ?? '—'}</div>
            <div class="pdf-kpi-sub">Active clients</div>
          </div>
        </div>
        <div class="pdf-divider"></div>`;
    }
 
    if (snap.aiAnalysis) {
      page1 += `
        <div class="pdf-section-label">AI Analysis</div>
        <div class="pdf-ai-box">
          <div class="pdf-ai-label">⚡ AI-Generated Insights</div>
          <div class="pdf-ai-text">${esc(snap.aiAnalysis.slice(0, 2000))}${snap.aiAnalysis.length > 2000 ? '\n\n[…continued on next section]' : ''}</div>
        </div>`;
    }
 
    page1 += footerHTML + '</div>';
 
    // ── PAGE 2: Forms + Organisations ──
    let page2 = `<div class="pdf-page">${headerHTML}`;
 
    if (snap.forms && snap.forms.length) {
      const formRows = snap.forms.slice(0, 20).map(f => `
        <tr>
          <td><strong>${esc(f.name)}</strong></td>
          <td style="color:#4a5270">${esc(f.description || '—')}</td>
          <td style="text-align:center">${f.fieldCount}</td>
          <td style="text-align:center">${f.responseCount}</td>
        </tr>`).join('');
 
      page2 += `
        <div class="pdf-section-label">Forms Overview (${snap.forms.length})</div>
        <table class="pdf-table">
          <thead>
            <tr><th>Form Name</th><th>Description</th><th style="text-align:center">Fields</th><th style="text-align:center">Responses</th></tr>
          </thead>
          <tbody>${formRows}</tbody>
        </table>
        <div class="pdf-divider"></div>`;
    }
 
    if (snap.organisations && snap.organisations.length) {
      page2 += `
        <div class="pdf-section-label">Organisations (${snap.organisations.length})</div>
        <div class="pdf-org-chips">
          ${snap.organisations.slice(0, 30).map(o =>
            `<span class="pdf-org-chip">${esc(o.name)}${o.industry ? ' · ' + esc(o.industry) : ''}</span>`
          ).join('')}
        </div>`;
    }
 
    page2 += footerHTML + '</div>';
 
    // ── PAGE 3: Responses ──
    let page3 = '';
    if (snap.responses && snap.responses.length) {
      const respRows = snap.responses.slice(0, 40).map(r => `
        <tr>
          <td><strong>${esc(r.respondent)}</strong></td>
          <td style="color:#4a5270">${esc(r.form)}</td>
          <td>${scorePill(r.score)}</td>
          <td style="color:#9099b8">${new Date(r.submittedAt).toLocaleDateString()}</td>
        </tr>`).join('');
 
      page3 = `
        <div class="pdf-page">
          ${headerHTML}
          <div class="pdf-section-label">
            Responses (${snap.responses.length}${snap.responses.length === 500 ? ' — first 500' : ''})
          </div>
          <table class="pdf-table">
            <thead>
              <tr><th>Respondent</th><th>Form</th><th>Score</th><th>Submitted</th></tr>
            </thead>
            <tbody>${respRows}</tbody>
          </table>
          ${snap.responses.length > 40
            ? `<div style="font-size:10px;color:#9099b8;margin-top:4px">Showing first 40 of ${snap.responses.length} responses. Export CSV for full dataset.</div>`
            : ''}
          ${footerHTML}
        </div>`;
    }
 
    // Render all pages into the hidden pane
    pane.innerHTML = page1 + page2 + page3;
 
    // Wait for fonts/layout
    loadingStep.textContent = 'Rendering pages…';
    await new Promise(r => setTimeout(r, 400));
 
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const pages = pane.querySelectorAll('.pdf-page');
    const A4_W  = 210;
    const A4_H  = 297;
 
    for (let i = 0; i < pages.length; i++) {
      loadingStep.textContent = `Capturing page ${i + 1} of ${pages.length}…`;
      if (i > 0) pdf.addPage();
 
      const canvas = await html2canvas(pages[i], {
        scale          : 2,
        useCORS        : true,
        allowTaint     : true,
        backgroundColor: '#ffffff',
        logging        : false,
        width          : 794,
      });
 
      const imgData = canvas.toDataURL('image/jpeg', 0.92);
      pdf.addImage(imgData, 'JPEG', 0, 0, A4_W, A4_H, undefined, 'FAST');
    }
 
    loadingStep.textContent = 'Saving PDF…';
    const fileName = `${report.title.replace(/[^a-z0-9]/gi, '_').toLowerCase()}_${Date.now()}.pdf`;
    pdf.save(fileName);
    toast('PDF exported!', 'success');
 
  } catch (e) {
    toast('PDF export failed: ' + e.message, 'error');
    console.error(e);
  } finally {
    loadingOverlay.classList.remove('active');
    document.getElementById('pdf-render-pane').innerHTML = '';
  }
};
 
 
/* ── HANDLE SHARE TOKEN IN URL ── */
(function checkReportTokenParam() {
  const token = new URLSearchParams(location.search).get('lumenos_report');
  if (!token) return;
 
  const tryLoad = setInterval(async () => {
    const { data: { session } } = await sb.auth.getSession();
    if (!session?.user) return;
    clearInterval(tryLoad);
 
    try {
      const { data, error } = await sb
        .from('il_reports')
        .select('*')
        .eq('share_token', token)
        .single();
 
      if (error || !data) { toast('Report not found or access denied', 'error'); return; }
 
      if (data.expires_at && new Date(data.expires_at) < new Date()) {
        toast('This report link has expired', 'error');
        return;
      }
 
      // Add to local cache and navigate
      if (!allReports.find(r => r.id === data.id)) allReports.unshift(data);
      currentReportId = data.id;
 
      // Clean URL
      history.replaceState(null, '', location.pathname);
 
      // Open share modal so they can see details / download PDF immediately
      openReportShareModal(data.id);
      toast(`Opened report: "${data.title}"`, 'success');
 
    } catch (e) {
      toast('Error loading report: ' + e.message, 'error');
    }
  }, 600);
})();
 
 
/* ── PATCH navTo to handle reports page ── */
const _originalNavTo = window.navTo;
window.navTo = function (page) {
  _originalNavTo(page);
  if (page === 'reports') renderReportsPage();
};

})();
</script>
