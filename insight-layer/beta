window.generateReportLink = function() {
  const scopeFormId  = document.getElementById('report-scope-form').value;
  const inclForms    = document.getElementById('rpt-include-forms').checked;
  const inclResp     = document.getElementById('rpt-include-responses').checked;
  const inclOrgs     = document.getElementById('rpt-include-orgs').checked;
  const inclMetrics  = document.getElementById('rpt-include-metrics').checked;
  const inclAI       = document.getElementById('rpt-include-ai').checked;
  const aiText       = document.getElementById('rpt-ai-text').value.trim();
  const expiryHours  = parseInt(document.getElementById('rpt-expiry').value, 10);

  // Build the data snapshot
  const scopedForms     = scopeFormId ? allForms.filter(f => f.id === scopeFormId) : allForms;
  const scopedResponses = scopeFormId ? allResponses.filter(r => r.form_id === scopeFormId) : allResponses;
  const scored          = scopedResponses.filter(r => r.readiness_score != null);
  const avgScore        = scored.length
    ? Math.round(scored.reduce((a, r) => a + r.readiness_score, 0) / scored.length)
    : null;

  const snapshot = {
    generatedAt : new Date().toISOString(),
    generatedBy : currentUser?.email || 'unknown',
    expiresAt   : expiryHours ? new Date(Date.now() + expiryHours * 3600000).toISOString() : null,
    metrics: inclMetrics ? {
      totalForms     : scopedForms.length,
      totalResponses : scopedResponses.length,
      avgScore,
      totalOrgs      : allOrgs.length,
    } : null,
    forms     : inclForms     ? scopedForms.map(f => ({
      id: f.id, name: f.name, description: f.description,
      fieldCount: (f.fields || []).length,
      responseCount: scopedResponses.filter(r => r.form_id === f.id).length,
    })) : null,
    responses : inclResp ? scopedResponses.slice(0, 500).map(r => ({
      id             : r.id,
      respondent     : r.respondent_name || 'Anonymous',
      form           : allForms.find(f => f.id === r.form_id)?.name || 'Unknown',
      score          : r.readiness_score,
      submittedAt    : r.created_at,
      answers        : r.answers || {},
    })) : null,
    organisations : inclOrgs ? allOrgs.map(o => ({
      id: o.id, name: o.name, industry: o.industry,
    })) : null,
    aiAnalysis : (inclAI && aiText) ? aiText : null,
  };

  // Encode as base64 in the URL hash — no server needed, operators only (auth still required to view app)
  let encoded;
  try {
    encoded = btoa(unescape(encodeURIComponent(JSON.stringify(snapshot))));
  } catch(e) {
    toast('Snapshot too large — try scoping to a single form or reducing included data', 'error');
    return;
  }

  const base   = location.href.split('?')[0].split('#')[0];
  const link   = `${base}?report=${encoded}`;

  document.getElementById('rpt-url-text').textContent = link;
  document.getElementById('rpt-link-section').style.display = 'block';

  const noteEl = document.getElementById('rpt-expiry-note');
  noteEl.textContent = expiryHours
    ? `This report expires ${new Date(Date.now() + expiryHours * 3600000).toLocaleString()}.`
    : 'This link never expires. Anyone with an operator account on this LumenOS instance can view it.';

  document.getElementById('rpt-generate-btn').textContent = 'Regenerate';
  toast('Report link generated!', 'success');
};

