function buildChatSystemPrompt(){
  const scopedForms=chatFormScope?allForms.filter(f=>f.id===chatFormScope):allForms;
  const scopedResponses=chatFormScope?allResponses.filter(r=>r.form_id===chatFormScope):allResponses;
  const formsSummary=scopedForms.map(f=>{
    const fResps=scopedResponses.filter(r=>r.form_id===f.id);
    const scored=fResps.filter(r=>r.readiness_score!=null);
    const avg=scored.length?Math.round(scored.reduce((a,r)=>a+r.readiness_score,0)/scored.length):null;
    return `- "${f.name}" (id:${f.id}): ${fResps.length} responses, avg score: ${avg??'N/A'}, fields: ${(f.fields||[]).map(ff=>ff.label+'('+ff.type+')').join(', ')}`;
  }).join('\n');
  const recentResponses=scopedResponses.slice(0,20).map((r,i)=>{
    const formName=allForms.find(f=>f.id===r.form_id)?.name||'Unknown';
    const answers=Object.entries(r.answers||{}).slice(0,4).map(([q,a])=>`${q}: ${Array.isArray(a)?a.join(', '):a}`).join(' | ');
    return `[${i+1}] ${r.respondent_name||'Anonymous'} → ${formName} | Score: ${r.readiness_score??'N/A'} | ${answers}`;
  }).join('\n');
  const scored=scopedResponses.filter(r=>r.readiness_score!=null);
  const avgAll=scored.length?Math.round(scored.reduce((a,r)=>a+r.readiness_score,0)/scored.length):null;
  return `You are LumenOS AI, an intelligent assistant for the LumenOS data platform. Answer questions using the live data provided below. Be concise and insightful.

## Platform Data Summary
- Total forms: ${scopedForms.length}
- Total responses: ${scopedResponses.length}  
- Average readiness score: ${avgAll??'N/A'}
- Organisations: ${allOrgs.length} (${allOrgs.map(o=>o.name).join(', ')||'none'})

## Forms
${formsSummary||'No forms yet.'}

## Recent Responses (up to 20)
${recentResponses||'No responses yet.'}

Instructions:
- Use the data above to answer questions directly. Do not say you cannot access data.
- Format responses with markdown (bold, lists, etc).
- Be analytical and specific — reference real numbers from the data.
- If asked about something not in the data, say so clearly.
- Keep responses focused and concise (under 400 words unless asked for more detail).`;
}
function appendChatMessage(role,content){
  const container=document.getElementById('chat-messages');if(!container)return;
  const div=document.createElement('div');div.className=`chat-msg ${role}`;
  div.innerHTML=renderMarkdown(content);container.appendChild(div);
  container.scrollTop=container.scrollHeight;
  if(role!=='system')chatHistory.push({role,content});
}
function showTyping(){
  const container=document.getElementById('chat-messages');if(!container)return;
  const div=document.createElement('div');div.id='chat-typing-indicator';div.className='chat-typing';
  div.innerHTML='<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
  container.appendChild(div);container.scrollTop=container.scrollHeight;
}
function hideTyping(){const el=document.getElementById('chat-typing-indicator');if(el)el.remove();}
function renderMarkdown(text){
  let t=text;
  t=t.replace(/```(\w*)\n?([\s\S]*?)```/g,(_,lang,code)=>`<pre><code>${esc(code.trim())}</code></pre>`);
  t=t.replace(/`([^`]+)`/g,(_,code)=>`<code>${esc(code)}</code>`);
  t=t.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
  t=t.replace(/\*([^*]+)\*/g,'<em>$1</em>');
  t=t.replace(/^### (.+)$/gm,'<strong style="font-size:13px;display:block;margin-top:8px;color:var(--accent)">$1</strong>');
  t=t.replace(/^## (.+)$/gm,'<strong style="font-size:14px;display:block;margin-top:10px">$1</strong>');
  t=t.replace(/^- (.+)$/gm,'<li style="margin-left:16px">$1</li>');
  t=t.replace(/(<li[^>]*>.*<\/li>\n?)+/g,m=>`<ul>${m}</ul>`);
  t=t.replace(/^\d+\. (.+)$/gm,'<li style="margin-left:16px">$1</li>');
  t=t.replace(/\n\n/g,'</p><p style="margin-top:6px">');
  t=t.replace(/\n/g,'<br>');
  return `<p style="margin:0">${t}</p>`;
}
window.sendChatMessage=async function(){
  if(chatSending)return;
  const input=document.getElementById('chat-input');const msg=input.value.trim();if(!msg)return;
  input.value='';input.style.height='auto';
  chatSending=true;const sendBtn=document.getElementById('chat-send-btn');if(sendBtn)sendBtn.disabled=true;
  appendChatMessage('user',msg);showTyping();
  try{
    const systemPrompt=buildChatSystemPrompt();
    const messages=chatHistory.filter(m=>m.role!=='system').slice(-20).map(m=>({role:m.role,content:m.content}));
    const response=await callAI(systemPrompt,messages);
    hideTyping();appendChatMessage('assistant',response);
  }catch(e){hideTyping();appendChatMessage('assistant',`❌ **Error:** ${e.message}`);}
  finally{chatSending=false;if(sendBtn)sendBtn.disabled=false;input.focus();}
};
window.clearChat=function(){chatHistory=[];initChat();toast('Chat cleared','info');};

