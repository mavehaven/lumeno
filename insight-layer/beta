/* ── HELPERS ── */
function esc(s){return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function timeAgo(d){const diff=Date.now()-new Date(d).getTime();if(diff<60000)return 'Just now';if(diff<3600000)return Math.floor(diff/60000)+'m ago';if(diff<86400000)return Math.floor(diff/3600000)+'h ago';return Math.floor(diff/86400000)+'d ago';}
function fmtBytes(b){if(b<1024)return b+'B';if(b<1048576)return (b/1024).toFixed(1)+'KB';return (b/1048576).toFixed(1)+'MB';}
function toast(msg,type='info'){
  const icons={
    success:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>',
    error:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
    info:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>'
  };
  const el=document.createElement('div');el.className='toast-item toast-'+type;el.innerHTML=(icons[type]||'')+esc(msg);
  document.getElementById('toast').appendChild(el);setTimeout(()=>el.remove(),3800);
}
function computeReadinessScore(answers,fields){
  let sum=0,count=0;
  (fields||[]).forEach(f=>{
    if(f.type==='scale'){const v=parseFloat(answers[f.label]);if(!isNaN(v)){sum+=((v-1)/9.0)*100;count++;}}
  });
  return count>0?Math.round(sum/count):null;
}
window.checkPasswordStrength=function(pw,fillId='pw-strength-fill'){
  const el=document.getElementById(fillId);if(!el)return;
  let score=0;
  if(pw.length>=8)score++;if(pw.length>=12)score++;
  if(/[A-Z]/.test(pw))score++;if(/[0-9]/.test(pw))score++;if(/[^A-Za-z0-9]/.test(pw))score++;
  const pct=(score/5)*100;const colors=['#ef4444','#f97316','#eab308','#22c55e','#16a34a'];
  el.style.width=pct+'%';el.style.background=colors[Math.min(score-1,4)]||'#ef4444';
};

