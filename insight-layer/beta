    btn.addEventListener('click',()=>{
      btn.closest('.fill-scale').querySelectorAll('.fill-scale-btn').forEach(b=>b.classList.remove('selected'));
      btn.classList.add('selected');updateFillProgress(fields);
    });
  });
  fields.forEach((f,i)=>{
    const isFileType=['image','pdf','csv','video','file'].includes(f.type);if(!isFileType)return;
    const zone=document.getElementById(`upload-zone-${i}`);const fileInput=document.getElementById(`upload-input-${i}`);if(!zone||!fileInput)return;
    zone.addEventListener('click',()=>fileInput.click());
    zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('dragover');});
    zone.addEventListener('dragleave',()=>zone.classList.remove('dragover'));
    zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('dragover');const file=e.dataTransfer.files[0];if(file)handleFileUpload(file,i,f.type,fields);});
    fileInput.addEventListener('change',()=>{const file=fileInput.files[0];if(file)handleFileUpload(file,i,f.type,fields);});
  });
  fieldsEl.querySelectorAll('input:not([type=file]),select,textarea').forEach(inp=>{
    inp.addEventListener('change',()=>updateFillProgress(fields));
    inp.addEventListener('input',()=>updateFillProgress(fields));
  });
  if(!FILL_PARAM){document.getElementById('fill-screen').style.display='block';document.body.style.overflow='hidden';}
}
async function handleFileUpload(file,idx,fieldType,fields){
  const maxSize=maxSizeForType(fieldType);if(file.size>maxSize){toast(`File too large. Max: ${fmtBytes(maxSize)}`,'error');return;}
  const previewWrap=document.getElementById(`upload-preview-${idx}`);const zone=document.getElementById(`upload-zone-${idx}`);
  if(previewWrap)previewWrap.innerHTML='<div class="upload-loading"><div class="spinner"></div>Uploading…</div>';
  let publicUrl=null,dataUrl=null;
  if(fieldType==='image'||file.size<5*1024*1024){
    dataUrl=await new Promise(res=>{const r=new FileReader();r.onload=e=>res(e.target.result);r.readAsDataURL(file);});
  }
  try{
    const ext=file.name.split('.').pop()||'bin';
    const path=`${bucketFolder(fieldType)}/${Date.now()}_${Math.random().toString(36).slice(2)}.${ext}`;
    const{data:upData,error:upErr}=await sb.storage.from('il-form-images').upload(path,file,{cacheControl:'3600',upsert:false,contentType:file.type});
    if(!upErr&&upData){const{data:urlData}=sb.storage.from('il-form-images').getPublicUrl(path);publicUrl=urlData?.publicUrl||null;}
  }catch(_){}
  fileUploads[idx]={file,dataUrl,publicUrl,fieldType};
  if(previewWrap){
    if(fieldType==='image'&&dataUrl){
      previewWrap.innerHTML=`<div class="image-preview-wrap"><img src="${dataUrl}" class="image-preview" onclick="openLightbox('${dataUrl}')"><button class="image-preview-remove" onclick="removeUpload(${idx})"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`;
    }else if(fieldType==='video'&&(publicUrl||dataUrl)){
      previewWrap.innerHTML=`<div style="position:relative;display:inline-block"><video src="${esc(publicUrl||dataUrl)}" class="video-preview" controls></video><button class="file-preview-remove" onclick="removeUpload(${idx})" style="position:absolute;top:4px;right:4px"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`;
    }else{
      previewWrap.innerHTML=`<div class="file-preview-doc"><div class="file-preview-doc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/></svg></div><div><div class="file-preview-doc-name">${esc(file.name)}</div><div class="file-preview-doc-size">${fmtBytes(file.size)}</div></div><button class="file-preview-remove" onclick="removeUpload(${idx})"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>`;
    }
    if(zone)zone.style.display='none';
  }
  updateFillProgress(fields);
}
