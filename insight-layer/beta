/* ── BUILD SNAPSHOT ── */
function buildReportSnapshot(scopeFormId, inclForms, inclResp, inclOrgs, inclMetrics, inclAI, aiText) {
  const scopedForms     = scopeFormId ? allForms.filter(f => f.id === scopeFormId)        : allForms;
  const scopedResponses = scopeFormId ? allResponses.filter(r => r.form_id === scopeFormId) : allResponses;
  const scored          = scopedResponses.filter(r => r.readiness_score != null);
  const avgScore        = scored.length
    ? Math.round(scored.reduce((a, r) => a + r.readiness_score, 0) / scored.length)
    : null;
 
  return {
    generatedAt  : new Date().toISOString(),
    generatedBy  : currentUser?.email || 'unknown',
    metrics      : inclMetrics ? {
      totalForms     : scopedForms.length,
      totalResponses : scopedResponses.length,
      avgScore,
      totalOrgs      : allOrgs.length,
      responsesLast24h: scopedResponses.filter(r =>
        Date.now() - new Date(r.created_at).getTime() < 86400000).length,
    } : null,
    forms        : inclForms ? scopedForms.map(f => ({
      id           : f.id,
      name         : f.name,
      description  : f.description,
      fieldCount   : (f.fields || []).length,
      responseCount: scopedResponses.filter(r => r.form_id === f.id).length,
    })) : null,
    responses    : inclResp ? scopedResponses.slice(0, 500).map(r => ({
      id          : r.id,
      respondent  : r.respondent_name || 'Anonymous',
      form        : allForms.find(f => f.id === r.form_id)?.name || 'Unknown',
      score       : r.readiness_score,
      submittedAt : r.created_at,
      answers     : r.answers || {},
    })) : null,
    organisations: inclOrgs ? allOrgs.map(o => ({
      id: o.id, name: o.name, industry: o.industry,
    })) : null,
    aiAnalysis   : (inclAI && aiText) ? aiText : null,
  };
}
 
 
/* ── SAVE REPORT ── */
window.saveReport = async function (andExportPDF = false) {
  const editId    = document.getElementById('nr-edit-id').value;
  const title     = document.getElementById('nr-title').value.trim();
  const scopeId   = document.getElementById('nr-scope-form').value;
  const expiryH   = parseInt(document.getElementById('nr-expiry').value, 10);
  const inclForms = document.getElementById('nr-incl-forms').checked;
  const inclResp  = document.getElementById('nr-incl-responses').checked;
  const inclOrgs  = document.getElementById('nr-incl-orgs').checked;
  const inclMet   = document.getElementById('nr-incl-metrics').checked;
  const inclAI    = document.getElementById('nr-incl-ai').checked;
  const aiText    = document.getElementById('nr-ai-text').value.trim();
 
  if (!title) { toast('Report title is required', 'error'); return; }
 
  const saveBtn = document.getElementById('nr-save-only-btn');
  const pdfBtn  = document.getElementById('nr-save-pdf-btn');
  saveBtn.disabled = true;
  pdfBtn.disabled  = true;
 
  const snapshot   = buildReportSnapshot(scopeId, inclForms, inclResp, inclOrgs, inclMet, inclAI, aiText);
  const expiresAt  = expiryH ? new Date(Date.now() + expiryH * 3600000).toISOString() : null;
  const shareToken = crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now().toString(36);
 
  try {
    let savedId = editId;
    if (editId) {
      // Update
      const { error } = await sb.from('il_reports').update({
        title,
        scope_form_id : scopeId || null,
        snapshot,
        expires_at    : expiresAt,
      }).eq('id', editId);
      if (error) throw error;
      toast('Report updated!', 'success');
    } else {
      // Insert
      const { data, error } = await sb.from('il_reports').insert([{
        title,
        created_by       : currentUser.id,
        created_by_email : currentUser.email,
        scope_form_id    : scopeId || null,
        snapshot,
        share_token      : shareToken,
        expires_at       : expiresAt,
      }]).select('id').single();
      if (error) throw error;
      savedId = data.id;
      toast('Report saved!', 'success');
    }
 
    closeModal('modal-new-report');
    await loadReports();
    if (document.getElementById('page-reports').classList.contains('active')) {
      renderReportsPage();
    }
 
    if (andExportPDF && savedId) {
      await exportReportPDF(savedId);
    }
  } catch (e) {
    toast('Error saving report: ' + e.message, 'error');
  } finally {
    saveBtn.disabled = false;
    pdfBtn.disabled  = false;
    saveBtn.textContent = 'Save';
    pdfBtn.textContent  = 'Save & Export PDF';
  }
};
 
 
