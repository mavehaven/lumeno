// Inline answer expander for the report viewer response table
window.toggleRespAnswers = function(row, encodedAnswers) {
  const existing = row.nextElementSibling;
  if (existing && existing.classList.contains('resp-expand-row')) {
    existing.remove(); return;
  }
  let answers = {};
  try { answers = JSON.parse(decodeURIComponent(atob(encodedAnswers))); } catch(e) {}
  const cells = Object.entries(answers).map(([q, a]) =>
    `<div class="resp-answer"><div class="resp-answer-q">${esc(q)}</div><div class="resp-answer-a">${esc(Array.isArray(a) ? a.join(', ') : String(a ?? '—'))}</div></div>`
  ).join('');
  const expandRow = document.createElement('tr');
  expandRow.className = 'resp-expand-row';
  expandRow.innerHTML = `<td colspan="5" style="padding:10px 12px;background:var(--bg)"><div class="resp-detail-grid">${cells || '<span style="font-size:12px;color:var(--text-3)">No answers recorded.</span>'}</div></td>`;
  row.after(expandRow);
};

