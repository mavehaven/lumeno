async function fireNotifications(form,respondentName,answers,score){
  const cfg=notifConfig;
  if(cfg.formScope&&cfg.formScope!==form.id)return;
  const formName=form.name||'Unknown Form';const respName=respondentName||'Anonymous';
  const scoreText=score!=null?`Score: ${score}`:'No score';const now=new Date().toLocaleString();
  const answerLines=Object.entries(answers).slice(0,5).map(([q,a])=>`<tr><td style="padding:4px 8px;color:#666;font-size:13px">${esc(q)}</td><td style="padding:4px 8px;font-size:13px">${esc(Array.isArray(a)?a.join(', '):String(a??'—'))}</td></tr>`).join('');
  if(cfg.email.enabled&&cfg.email.address){
    if(!cfg.email.edgeFnUrl){addNotifLog('email','fail','Not sent — Edge Function URL not configured');}
    else{
      addNotifLog('email','pending',`Sending to ${cfg.email.address}…`);
      try{
        const html=`<div style="font-family:sans-serif;max-width:520px;margin:0 auto"><div style="background:#4f63e8;padding:20px 24px;border-radius:10px 10px 0 0"><h2 style="color:white;margin:0;font-size:18px">📋 New Response — ${esc(formName)}</h2></div><div style="background:#f8f9ff;padding:20px 24px;border:1px solid #e0e3f4;border-top:none"><p style="margin:0 0 12px;color:#1a1d2e"><strong>Respondent:</strong> ${esc(respName)}</p><p style="margin:0 0 12px;color:#1a1d2e"><strong>${scoreText}</strong></p><p style="margin:0 0 8px;color:#4a5270;font-size:13px">Submitted at ${now}</p><table style="width:100%;border-collapse:collapse;margin-top:12px;background:white;border-radius:8px;overflow:hidden;border:1px solid #e0e3f4"><thead><tr style="background:#4f63e8"><th style="padding:8px;color:white;text-align:left;font-size:12px">Question</th><th style="padding:8px;color:white;text-align:left;font-size:12px">Answer</th></tr></thead><tbody>${answerLines}</tbody></table></div></div>`;
        const res=await fetch(cfg.email.edgeFnUrl,{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${SUPABASE_KEY}`},body:JSON.stringify({to:cfg.email.address,subject:`[LumenOS] New response: ${formName}`,html})});
        if(!res.ok)throw new Error(`HTTP ${res.status}`);
        if(notifLog[0]?.status==='pending'){notifLog[0].status='ok';notifLog[0].message=`Email sent to ${cfg.email.address} — ${formName}`;}
        localStorage.setItem('lumenos_notif_log',JSON.stringify(notifLog));renderNotifLog();toast('Email notification sent!','success');
      }catch(e){if(notifLog[0]?.status==='pending'){notifLog[0].status='fail';notifLog[0].message=`Email failed: ${e.message}`;}localStorage.setItem('lumenos_notif_log',JSON.stringify(notifLog));renderNotifLog();}
    }
  }
  if(cfg.slack.enabled&&cfg.slack.webhookUrl){
    addNotifLog('slack','pending','Posting to Slack…');
    const answerText=Object.entries(answers).slice(0,5).map(([q,a])=>`*${q}:* ${Array.isArray(a)?a.join(', '):String(a??'—')}`).join('\n');
    const payload={blocks:[{type:'header',text:{type:'plain_text',text:`📋 New Response: ${formName}`,emoji:true}},{type:'section',fields:[{type:'mrkdwn',text:`*Respondent:*\n${respName}`},{type:'mrkdwn',text:`*${scoreText}*\n${now}`}]},answerText?{type:'section',text:{type:'mrkdwn',text:answerText}}:null,{type:'actions',elements:[{type:'button',text:{type:'plain_text',text:'View in LumenOS →'},url:location.href.split('?')[0],style:'primary'}]}].filter(Boolean)};
    try{
      await fetch(cfg.slack.webhookUrl,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload),mode:'no-cors'});
      if(notifLog[0]?.status==='pending'){notifLog[0].status='ok';notifLog[0].message=`Slack message sent — ${formName} / ${respName}`;}
      localStorage.setItem('lumenos_notif_log',JSON.stringify(notifLog));renderNotifLog();toast('Slack notification sent!','success');
    }catch(e){if(notifLog[0]?.status==='pending'){notifLog[0].status='fail';notifLog[0].message=`Slack failed: ${e.message}`;}localStorage.setItem('lumenos_notif_log',JSON.stringify(notifLog));renderNotifLog();}
  }
}
