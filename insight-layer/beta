async function renderMetrics(){
  Object.values(metricsCharts).forEach(c=>{try{c.destroy();}catch(e){}});metricsCharts={};
  let volLabels=[],volData=[];
  try{
    const{data,error}=await sb.rpc('il_response_volume',{p_days:30});
    if(!error&&data&&data.length){volLabels=data.map(r=>new Date(r.day).toLocaleDateString('en',{month:'short',day:'numeric'}));volData=data.map(r=>Number(r.response_count));}
  }catch(_){}
  if(!volLabels.length){
    for(let i=29;i>=0;i--){
      const d=new Date();d.setDate(d.getDate()-i);
      volLabels.push(d.toLocaleDateString('en',{month:'short',day:'numeric'}));
      const s=new Date(d).setHours(0,0,0,0);
      volData.push(allResponses.filter(r=>{const t=new Date(r.created_at).getTime();return t>=s&&t<s+86400000;}).length);
    }
  }
  const vc=document.getElementById('metrics-chart-volume');
  if(vc){metricsCharts.volume=new Chart(vc,{type:'bar',data:{labels:volLabels,datasets:[{label:'Responses',data:volData,backgroundColor:'rgba(79,99,232,0.3)',borderColor:'#4f63e8',borderWidth:1,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{font:{size:9},color:'#9099b8',maxTicksLimit:6}},y:{grid:{color:'rgba(0,0,0,0.05)'},ticks:{font:{size:9},color:'#9099b8'}}}}});}
  let scoreLabels=[],scoreData=[],scoreColors=[];
  try{
    const{data,error}=await sb.rpc('il_score_distribution');
    if(!error&&data&&data.length){scoreLabels=data.map(r=>r.bucket);scoreData=data.map(r=>Number(r.response_count));scoreColors=scoreLabels.map(b=>b==='0–39'?'rgba(220,38,38,0.5)':b==='40–59'?'rgba(217,119,6,0.5)':b==='60–79'?'rgba(79,99,232,0.5)':'rgba(22,163,74,0.5)');}
  }catch(_){}
  if(!scoreLabels.length){
    const buckets={'0–39':0,'40–59':0,'60–79':0,'80–100':0};
    allResponses.filter(r=>r.readiness_score!=null).forEach(r=>{const s=r.readiness_score;if(s<40)buckets['0–39']++;else if(s<60)buckets['40–59']++;else if(s<80)buckets['60–79']++;else buckets['80–100']++;});
    scoreLabels=Object.keys(buckets);scoreData=Object.values(buckets);
    scoreColors=['rgba(220,38,38,0.5)','rgba(217,119,6,0.5)','rgba(79,99,232,0.5)','rgba(22,163,74,0.5)'];
  }
  const sc=document.getElementById('metrics-chart-score');
  if(sc){metricsCharts.score=new Chart(sc,{type:'bar',data:{labels:scoreLabels,datasets:[{data:scoreData,backgroundColor:scoreColors,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{font:{size:9},color:'#9099b8'}},y:{grid:{color:'rgba(0,0,0,0.05)'},ticks:{font:{size:9},color:'#9099b8'}}}}});}
  const topFormRows=allForms.map(f=>({...f,count:allResponses.filter(r=>r.form_id===f.id).length})).sort((a,b)=>b.count-a.count).slice(0,5).map(f=>`<div class="met-row"><div class="met-label">${esc(f.name)}</div><div class="met-val">${f.count}</div></div>`);
  document.getElementById('metrics-top-forms').innerHTML=topFormRows.length?topFormRows.join(''):'<div style="font-size:12.5px;color:var(--text-3)">No data yet.</div>';
  document.getElementById('metrics-top-orgs').innerHTML=allOrgs.slice(0,5).length?allOrgs.slice(0,5).map(o=>`<div class="person-row"><div class="person-avatar" style="border-radius:6px">${o.name[0].toUpperCase()}</div><div><div class="person-name">${esc(o.name)}</div><div class="person-status">${esc(o.industry||'General')}</div></div></div>`).join(''):'<div style="font-size:12.5px;color:var(--text-3)">No organisations yet.</div>';
  const scored=allResponses.filter(r=>r.readiness_score!=null);
  const avgScore=scored.length?Math.round(scored.reduce((a,r)=>a+r.readiness_score,0)/scored.length):null;
  document.getElementById('metrics-summary').innerHTML=`<div class="met-row"><div class="met-label">Total Forms</div><div class="met-val">${allForms.length}</div></div><div class="met-row"><div class="met-label">Total Responses</div><div class="met-val">${allResponses.length}</div></div><div class="met-row"><div class="met-label">Avg Score</div><div class="met-val">${avgScore??'—'}</div></div><div class="met-row" style="border:none"><div class="met-label">Organisations</div><div class="met-val">${allOrgs.length}</div></div>`;
}

