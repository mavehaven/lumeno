window.handleSearch=function(val){
  document.getElementById('sb-search-input').value=val;document.getElementById('cmd-input').value=val;
  clearTimeout(searchDebounce);if(!val.trim()){hideSearchResults();return;}
  searchDebounce=setTimeout(()=>runSearch(val.trim()),300);
};
async function runSearch(q){
  try{
    const{data,error}=await sb.rpc('il_search',{p_query:q});
    if(!error&&data&&data.length){showSearchResults(data);return;}
  }catch(_){}
  const results=[];
  allForms.filter(f=>f.name.toLowerCase().includes(q.toLowerCase())).slice(0,5).forEach(f=>results.push({result_type:'form',id:f.id,title:f.name,subtitle:f.description||'Form'}));
  allResponses.filter(r=>(r.respondent_name||'').toLowerCase().includes(q.toLowerCase())).slice(0,5).forEach(r=>{const form=allForms.find(f=>f.id===r.form_id);results.push({result_type:'response',id:r.id,title:r.respondent_name||'Anonymous',subtitle:form?.name||'Unknown form'});});
  allOrgs.filter(o=>o.name.toLowerCase().includes(q.toLowerCase())).slice(0,3).forEach(o=>results.push({result_type:'org',id:o.id,title:o.name,subtitle:o.industry||'Organisation'}));
  showSearchResults(results);
}
function showSearchResults(results){
  const typeMap={form:{cls:'srt-form',label:'Form'},response:{cls:'srt-response',label:'Response'},org:{cls:'srt-org',label:'Org'}};
  const html=results.slice(0,10).map(r=>{
    const t=typeMap[r.result_type]||{cls:'',label:r.result_type};
    return `<div class="search-result-item" onclick="handleSearchResultClick('${r.result_type}','${r.id}')"><span class="search-result-type ${t.cls}">${t.label}</span><div><div class="search-result-title">${esc(r.title)}</div><div class="search-result-sub">${esc(r.subtitle)}</div></div></div>`;
  }).join('');
  ['sb-search-results','cmd-search-results'].forEach(id=>{
    const el=document.getElementById(id);
    if(el){el.innerHTML=html||'<div style="padding:10px 12px;font-size:12px;color:var(--text-3)">No results found</div>';el.style.display='block';}
  });
}
function hideSearchResults(){
  ['sb-search-results','cmd-search-results'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.display='none';});
}
window.handleSearchResultClick=function(type,id){
