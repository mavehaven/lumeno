<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LumenOS | Intelligence Activation System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
:root {
  --bg:#f4f5f9;--surface:#fff;--surface-2:#f0f1f6;--surface-3:#e8eaf2;
  --border:rgba(0,0,0,.08);--border-2:rgba(0,0,0,.13);
  --text-1:#1a1d2e;--text-2:#4a5270;--text-3:#9099b8;
  --accent:#4f63e8;--accent-2:#3a50d4;--accent-glow:rgba(79,99,232,.15);--accent-soft:rgba(79,99,232,.10);
  --green:#16a34a;--green-soft:rgba(22,163,74,.10);
  --amber:#d97706;--amber-soft:rgba(217,119,6,.10);
  --red:#dc2626;--red-soft:rgba(220,38,38,.10);
  --purple:#7c3aed;--purple-soft:rgba(124,58,237,.10);
  --nav-w:60px;--sidebar-w:240px;--radius:12px;--radius-sm:8px;
  --font:'DM Sans',system-ui,sans-serif;--font-alt:'Syne',system-ui,sans-serif;--font-serif:'DM Serif Display',serif;
  --shadow:0 1px 6px rgba(0,0,0,.07),0 2px 12px rgba(0,0,0,.05);
  --shadow-md:0 4px 20px rgba(0,0,0,.10),0 1px 4px rgba(0,0,0,.06);
  --t:0.16s cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-size:14px;-webkit-font-smoothing:antialiased}
body{background:var(--bg);color:var(--text-1);font-family:var(--font);line-height:1.5;overflow-x:hidden}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border-2);border-radius:10px}
button{font-family:var(--font);cursor:pointer}
input,select,textarea{font-family:var(--font)}
a{color:inherit;text-decoration:none}

body.fill-only-mode #auth-screen,body.fill-only-mode #app{display:none!important}
body.fill-only-mode #fill-screen{display:block!important}

#auth-screen{position:fixed;inset:0;z-index:999;display:flex;align-items:center;justify-content:center;background:radial-gradient(ellipse at 30% 40%,rgba(79,99,232,.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 70%,rgba(124,58,237,.05) 0%,transparent 50%),var(--bg)}
.auth-card{width:100%;max-width:400px;background:var(--surface);border:1px solid var(--border-2);border-radius:18px;padding:36px 32px;box-shadow:var(--shadow-md)}
.auth-logo{height:26px;margin-bottom:26px;object-fit:contain}
.auth-title{font-family:var(--font-serif);font-size:22px;margin-bottom:4px;color:var(--text-1)}
.auth-desc{font-size:12.5px;color:var(--text-2);margin-bottom:22px}
.auth-tabs{display:flex;gap:3px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:3px;margin-bottom:20px}
.auth-tab{flex:1;padding:7px;background:none;border:none;border-radius:6px;font-size:12.5px;font-weight:500;color:var(--text-2);transition:var(--t)}
.auth-tab.active{background:var(--surface);color:var(--text-1);box-shadow:var(--shadow)}
.auth-panel{display:none}
.auth-panel.active{display:block}
.f-group{margin-bottom:12px}
.f-label{display:block;font-size:11.5px;font-weight:500;color:var(--text-2);margin-bottom:4px}
.f-input{width:100%;padding:9px 11px;background:var(--bg);border:1px solid var(--border-2);border-radius:var(--radius-sm);font-size:13px;color:var(--text-1);outline:none;transition:var(--t)}
.f-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
.btn-auth{width:100%;padding:11px;margin-top:4px;background:var(--accent);color:white;border:none;border-radius:var(--radius);font-weight:600;font-size:14px;transition:var(--t);letter-spacing:.01em}
.btn-auth:hover{background:var(--accent-2);transform:translateY(-1px);box-shadow:0 5px 20px rgba(79,99,232,.3)}
.btn-auth:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
.auth-msg{font-size:12px;text-align:center;margin-top:10px;padding:7px 10px;border-radius:var(--radius-sm);display:none}
.auth-msg.error{background:var(--red-soft);color:var(--red);display:block;border:1px solid rgba(220,38,38,.2)}
.auth-msg.success{background:var(--green-soft);color:var(--green);display:block;border:1px solid rgba(22,163,74,.2)}
.auth-forgot{display:block;text-align:right;font-size:11.5px;color:var(--accent);margin-top:-6px;margin-bottom:12px;cursor:pointer;background:none;border:none;padding:0;transition:var(--t)}
.auth-forgot:hover{opacity:.75}
.auth-back{display:flex;align-items:center;gap:5px;font-size:11.5px;color:var(--text-3);background:none;border:none;cursor:pointer;margin-bottom:14px;transition:var(--t);padding:0}
.auth-back:hover{color:var(--text-1)}
.auth-back svg{width:12px;height:12px;stroke:currentColor;stroke-width:2;fill:none}
.pw-strength-bar{height:3px;border-radius:2px;margin-top:5px;background:var(--surface-3);overflow:hidden}
.pw-strength-fill{height:100%;border-radius:2px;transition:width .3s ease,background .3s ease;width:0%}

#app{display:none;min-height:100vh}
.icon-nav{position:fixed;left:0;top:0;bottom:0;width:var(--nav-w);z-index:200;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:12px 0;gap:2px}
.icon-nav-logo{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;cursor:pointer;overflow:hidden;box-shadow:0 2px 8px rgba(79,99,232,.2)}
.icon-nav-logo img{width:100%;height:100%;object-fit:contain;display:block}
.nav-btn{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;transition:var(--t);color:var(--text-3);background:none;border:none}
.nav-btn:hover{background:var(--surface-2);color:var(--text-2)}
.nav-btn.active{background:var(--accent-soft);color:var(--accent)}
.nav-btn svg{width:17px;height:17px;stroke-width:1.8}
.nav-badge{position:absolute;top:4px;right:4px;width:7px;height:7px;border-radius:50%;background:var(--red);border:2px solid var(--surface)}
.nav-spacer{flex:1}
.nav-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--purple));display:flex;align-items:center;justify-content:center;font-family:var(--font-alt);font-weight:700;font-size:12px;color:white;cursor:pointer;margin-top:8px}
.nav-tooltip{position:absolute;left:calc(var(--nav-w) + 6px);top:50%;transform:translateY(-50%);background:var(--text-1);border:1px solid rgba(0,0,0,.1);color:white;font-size:11.5px;font-weight:500;padding:4px 9px;border-radius:6px;white-space:nowrap;opacity:0;pointer-events:none;transition:var(--t);z-index:300;box-shadow:var(--shadow)}
.nav-btn:hover .nav-tooltip{opacity:1}
.sidebar{position:fixed;left:var(--nav-w);top:0;bottom:0;width:var(--sidebar-w);z-index:190;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto}
.sb-header{padding:14px 12px 10px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--surface);z-index:1;border-bottom:1px solid var(--border)}
.sb-logo{height:22px;object-fit:contain}
.sb-add{width:24px;height:24px;border-radius:6px;background:var(--accent-soft);border:none;color:var(--accent);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:var(--t)}
.sb-add:hover{background:rgba(79,99,232,.18)}
.sb-add svg{width:12px;height:12px;stroke-width:2.5;stroke:currentColor;fill:none}
.sb-search{margin:9px 10px 4px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);display:flex;align-items:center;gap:7px;padding:6px 9px;position:relative}
.sb-search svg{width:12px;height:12px;color:var(--text-3);flex-shrink:0;stroke-width:2;stroke:currentColor;fill:none}
.sb-search input{background:none;border:none;outline:none;font-size:12px;color:var(--text-1);width:100%}
.sb-search input::placeholder{color:var(--text-3)}
.sb-section{padding:0 6px;margin-bottom:2px}
.sb-section-label{font-family:var(--font-alt);font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-3);padding:9px 8px 4px}
.sb-item{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:var(--radius-sm);cursor:pointer;transition:var(--t);font-size:12.5px;font-weight:400;color:var(--text-2);border:none;background:none;width:100%;text-align:left}
.sb-item:hover{background:var(--surface-2);color:var(--text-1)}
.sb-item.active{background:var(--accent-soft);color:var(--accent);font-weight:500}
.sb-item-icon{width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:var(--surface-2)}
.sb-item.active .sb-item-icon{background:rgba(79,99,232,.15)}
.sb-item-icon svg{width:11px;height:11px;stroke-width:2;stroke:currentColor;fill:none}
.sb-item-name{flex:1}
.sb-count{font-size:10px;color:var(--text-3);background:var(--surface-2);padding:1px 5px;border-radius:20px}
.sb-item.active .sb-count{background:rgba(79,99,232,.15);color:var(--accent)}
.sb-footer{margin-top:auto;padding:12px;border-top:1px solid var(--border)}
.sb-org-label{font-family:var(--font-alt);font-size:9.5px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);margin-bottom:5px}
.sb-org-sel{width:100%;padding:6px 8px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:12px;color:var(--text-1);outline:none;margin-bottom:8px}
.btn-signout{width:100%;padding:7px;background:none;border:1px solid var(--border-2);border-radius:var(--radius-sm);font-size:12px;font-weight:500;color:var(--text-2);transition:var(--t)}
.btn-signout:hover{border-color:var(--red);color:var(--red)}
.main{margin-left:calc(var(--nav-w) + var(--sidebar-w));min-height:100vh;padding:24px 26px;max-width:1400px}
.cmd-bar{position:sticky;top:0;z-index:100;background:rgba(244,245,249,.9);backdrop-filter:blur(16px);margin:-24px -26px 22px;padding:10px 26px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.cmd-wrap{flex:1;max-width:420px;background:var(--surface);border:1px solid var(--border-2);border-radius:var(--radius);display:flex;align-items:center;gap:8px;padding:7px 12px;box-shadow:var(--shadow);position:relative}
.cmd-wrap svg{width:13px;height:13px;color:var(--text-3);stroke-width:2;stroke:currentColor;fill:none;flex-shrink:0}
.cmd-wrap input{background:none;border:none;outline:none;font-size:12.5px;color:var(--text-1);flex:1}
.cmd-wrap input::placeholder{color:var(--text-3)}
.cmd-kbd{font-family:var(--font-alt);font-size:10px;color:var(--text-3);background:var(--surface-2);padding:2px 5px;border-radius:4px;border:1px solid var(--border-2)}
.cmd-right{display:flex;align-items:center;gap:5px;margin-left:auto}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 12px;border-radius:var(--radius-sm);font-size:12.5px;font-weight:500;transition:var(--t);border:none}
.btn svg{width:12px;height:12px;stroke-width:2;stroke:currentColor;fill:none}
.btn-ghost{background:none;color:var(--text-2)}
.btn-ghost:hover{background:var(--surface-2);color:var(--text-1)}
.btn-accent{background:var(--accent);color:white}
.btn-accent:hover{background:var(--accent-2);box-shadow:0 3px 12px rgba(79,99,232,.25)}
.btn-outline{background:var(--surface);color:var(--text-1);border:1px solid var(--border-2)}
.btn-outline:hover{border-color:var(--accent);color:var(--accent)}
.btn-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;transition:var(--t);flex-shrink:0}
.btn-icon svg{width:12px;height:12px;stroke-width:2;stroke:currentColor;fill:none}
.btn-icon-ghost{background:var(--surface-2);color:var(--text-2)}
.btn-icon-ghost:hover{background:var(--surface-3);color:var(--text-1)}
.btn-icon-accent{background:var(--accent-soft);color:var(--accent)}
.btn-icon-accent:hover{background:rgba(79,99,232,.18)}
.btn-icon-green{background:var(--green-soft);color:var(--green)}
.btn-icon-green:hover{background:rgba(22,163,74,.18)}
.btn-icon-red{background:var(--red-soft);color:var(--red)}
.btn-icon-red:hover{background:rgba(220,38,38,.18)}
.page{display:none}
.page.active{display:block;animation:fadeIn .2s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.page-title{font-family:var(--font-serif);font-size:24px;font-weight:400;letter-spacing:-.01em;line-height:1.2;margin-bottom:3px}
.page-title em{font-style:italic;color:var(--accent)}
.page-sub{font-size:12.5px;color:var(--text-2);margin-bottom:20px}
.page-header-row{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow);overflow:hidden}
.card-sm{padding:14px}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.card-label{font-family:var(--font-alt);font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-3)}
.card-action{font-size:11.5px;color:var(--accent);cursor:pointer;font-weight:500;display:flex;align-items:center;gap:3px;border:none;background:none;padding:0}
.card-action:hover{opacity:.75}
.card-action svg{width:11px;height:11px;stroke-width:2.5;stroke:currentColor;fill:none}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;position:relative;overflow:hidden;box-shadow:var(--shadow);transition:var(--t)}
.kpi-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);border-color:var(--border-2)}
.kpi-glow{position:absolute;top:-15px;right:-15px;width:70px;height:70px;border-radius:50%;opacity:.08}
.kpi-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:12px}
.kpi-icon svg{width:15px;height:15px;stroke-width:2;stroke:currentColor;fill:none}
.kpi-label{font-family:var(--font-alt);font-size:9.5px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text-3);margin-bottom:5px}
.kpi-value{font-family:var(--font-alt);font-size:30px;font-weight:700;letter-spacing:-.03em;color:var(--text-1);line-height:1}
.kpi-sub{font-size:11px;color:var(--text-3);margin-top:5px}
.kpi-sub.up{color:var(--green)}
.kpi-sub.down{color:var(--red)}
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:11px;font-weight:500}
.badge-blue{background:var(--accent-soft);color:var(--accent)}
.badge-green{background:var(--green-soft);color:var(--green)}
.badge-red{background:var(--red-soft);color:var(--red)}
.badge-amber{background:var(--amber-soft);color:var(--amber)}
.badge-grey{background:var(--surface-2);color:var(--text-2)}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
thead th{font-family:var(--font-alt);font-size:9.5px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text-3);padding:9px 12px;text-align:left;border-bottom:1px solid var(--border);background:var(--bg);white-space:nowrap}
tbody td{padding:10px 12px;font-size:12.5px;border-bottom:1px solid var(--border);color:var(--text-1)}
tbody tr:hover td{background:var(--surface-2)}
tbody tr:last-child td{border-bottom:none}
.insight-item{display:flex;align-items:flex-start;gap:9px;padding:8px 0;border-bottom:1px solid var(--border)}
.insight-item:last-child{border-bottom:none}
.insight-icon{width:26px;height:26px;border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.insight-icon svg{width:12px;height:12px;stroke-width:2;stroke:currentColor;fill:none}
.insight-text{font-size:12.5px;color:var(--text-1);line-height:1.45;flex:1}
.insight-time{font-size:11px;color:var(--text-3);margin-top:2px}
.insight-footer{display:flex;align-items:center;gap:4px;font-size:11.5px;color:var(--accent);font-weight:500;padding-top:8px;cursor:pointer;border:none;background:none}
.insight-footer svg{width:12px;height:12px;stroke-width:2;stroke:currentColor;fill:none}
.person-row{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid var(--border)}
.person-row:last-child{border-bottom:none}
.person-avatar{width:28px;height:28px;border-radius:50%;flex-shrink:0;background:var(--surface-2);display:flex;align-items:center;justify-content:center;font-family:var(--font-alt);font-weight:700;font-size:11px;color:var(--accent)}
.person-name{font-size:12.5px;font-weight:500;color:var(--text-1)}
.person-status{font-size:11px;color:var(--text-3)}
.snap-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border)}
.snap-row:last-child{border-bottom:none}
.snap-label{font-size:11.5px;color:var(--text-2)}
.snap-value{font-family:var(--font-alt);font-size:17px;font-weight:700;letter-spacing:-.02em;color:var(--text-1)}
.snap-chart-wrap{width:68px;height:30px;position:relative;flex-shrink:0}
.snap-chart-wrap canvas{position:absolute!important;inset:0;width:100%!important;height:100%!important}
.qa-item{display:flex;align-items:center;gap:8px;padding:7px 6px;border-radius:var(--radius-sm);cursor:pointer;transition:var(--t);border:none;background:none;width:100%;text-align:left}
.qa-item:hover{background:var(--surface-2)}
.qa-icon{width:28px;height:28px;border-radius:7px;flex-shrink:0;background:var(--surface-2);display:flex;align-items:center;justify-content:center}
.qa-icon svg{width:13px;height:13px;stroke-width:2;stroke:currentColor;fill:none}
.qa-name{font-size:12.5px;color:var(--text-1);flex:1}
.qa-arr svg{width:12px;height:12px;stroke-width:2;stroke:var(--text-3);fill:none}
.focus-card{background:linear-gradient(135deg,#eef0fd,#f5f3ff);border:1px solid rgba(79,99,232,.15);border-radius:var(--radius);padding:14px;position:relative;overflow:hidden}
.focus-card::before{content:'';position:absolute;top:-20px;right:-20px;width:80px;height:80px;border-radius:50%;background:var(--accent);opacity:.06}
.focus-title{font-family:var(--font-alt);font-size:9.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px}
.focus-mode{font-family:var(--font-alt);font-size:14px;font-weight:600;color:var(--text-1);margin-bottom:1px}
.focus-time{font-size:11px;color:var(--text-3);margin-bottom:10px}
.focus-ring{width:46px;height:46px;border-radius:50%;border:2px solid rgba(79,99,232,.15);border-top-color:var(--accent);animation:spin 8s linear infinite;flex-shrink:0;position:relative}
.focus-ring-inner{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--font-alt);font-size:10px;font-weight:600;color:var(--accent);animation:spin 8s linear infinite reverse}
@keyframes spin{to{transform:rotate(360deg)}}
.btn-pause{padding:5px 10px;background:rgba(0,0,0,.05);border:1px solid rgba(0,0,0,.1);border-radius:6px;font-size:11.5px;font-weight:500;color:var(--text-2);display:flex;align-items:center;gap:4px;transition:var(--t)}
.btn-pause:hover{background:rgba(0,0,0,.08);color:var(--text-1)}
.btn-pause svg{width:10px;height:10px;stroke-width:2;stroke:currentColor;fill:none}
.glance-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border)}
.glance-row:last-child{border-bottom:none}
.glance-icon{width:26px;height:26px;border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:var(--surface-2)}
.glance-icon svg{width:11px;height:11px;stroke-width:2;stroke:currentColor;fill:none;color:var(--text-2)}
.glance-label{font-size:10.5px;color:var(--text-3)}
.glance-value{font-size:12.5px;color:var(--text-1);font-weight:500}
.form-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:15px;box-shadow:var(--shadow);transition:var(--t)}
.form-card:hover{box-shadow:var(--shadow-md);border-color:var(--border-2)}
.form-card-title{font-weight:600;font-size:13.5px;margin-bottom:4px;color:var(--text-1)}
.form-card-desc{font-size:12px;color:var(--text-2);margin-bottom:10px;line-height:1.5}
.form-card-footer{display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.form-card-actions{display:flex;gap:5px;margin-top:10px}
.insight-map{position:relative;height:220px;background:var(--bg);border-radius:var(--radius-sm);overflow:hidden;border:1px solid var(--border)}
.chart-container{position:relative;width:100%;height:190px}
.chart-container canvas{position:absolute!important;inset:0;width:100%!important;height:100%!important}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);backdrop-filter:blur(6px);z-index:800;display:none;align-items:center;justify-content:center;padding:20px}
.modal-overlay.open{display:flex}
.modal{background:var(--surface);border-radius:var(--radius);border:1px solid var(--border-2);box-shadow:0 20px 60px rgba(0,0,0,.2);width:100%;max-height:90vh;overflow-y:auto}
.modal-sm{max-width:400px}
.modal-md{max-width:540px}
.modal-header{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--surface);z-index:1}
.modal-title{font-family:var(--font-alt);font-weight:600;font-size:14px;color:var(--text-1)}
.modal-close{background:var(--surface-2);border:none;border-radius:6px;width:24px;height:24px;cursor:pointer;color:var(--text-2);display:flex;align-items:center;justify-content:center;transition:var(--t)}
.modal-close:hover{background:var(--red-soft);color:var(--red)}
.modal-close svg{width:11px;height:11px;stroke-width:2;stroke:currentColor;fill:none}
.modal-body{padding:16px}
.modal-footer{padding:11px 16px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:6px}
.form-row{margin-bottom:11px}
.form-label{display:block;font-size:11.5px;font-weight:500;color:var(--text-2);margin-bottom:4px}
.form-input,.form-select,.form-textarea{width:100%;padding:8px 10px;background:var(--bg);border:1px solid var(--border-2);border-radius:var(--radius-sm);font-family:var(--font);font-size:12.5px;color:var(--text-1);outline:none;transition:var(--t)}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
.form-textarea{resize:vertical;min-height:75px}
.form-select option{background:var(--surface);color:var(--text-1)}
.field-builder-list{display:flex;flex-direction:column;gap:6px;margin-bottom:10px;max-height:200px;overflow-y:auto}
.field-item{display:flex;align-items:center;gap:7px;padding:7px 9px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm)}
.field-item-label{flex:1;font-size:12.5px;color:var(--text-1)}
.field-item-type{font-size:10px;color:var(--text-3);background:var(--surface);padding:2px 6px;border-radius:10px;border:1px solid var(--border)}
.field-add-row{display:flex;gap:5px}
.field-add-row .form-input{flex:1}
.share-tabs{display:flex;gap:3px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:3px;margin-bottom:13px}
.share-tab{flex:1;padding:6px;background:none;border:none;border-radius:5px;font-size:12px;font-weight:500;color:var(--text-2);cursor:pointer;transition:var(--t)}
.share-tab.active{background:var(--surface);color:var(--text-1);box-shadow:var(--shadow)}
.share-panel{display:none}
.share-panel.active{display:block}
.qr-wrap{padding:14px;background:white;border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:10px;border:1px solid var(--border);min-height:208px}
.url-row{display:flex;align-items:center;gap:6px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 9px;margin-bottom:8px}
.url-text{flex:1;font-size:11px;color:var(--text-2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:monospace}
.btn-copy{flex-shrink:0;padding:3px 8px;border-radius:5px;background:var(--accent-soft);color:var(--accent);border:none;font-size:11px;font-weight:500;cursor:pointer;transition:var(--t)}
.btn-copy:hover{background:rgba(79,99,232,.18)}
.share-platforms{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:10px}
.platform-btn{display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 4px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--bg);cursor:pointer;transition:var(--t);font-size:10px;color:var(--text-2);font-weight:500}
.platform-btn:hover{border-color:var(--accent);background:var(--accent-soft);color:var(--accent)}
.platform-icon{width:24px;height:24px;border-radius:5px;display:flex;align-items:center;justify-content:center}
.platform-icon svg{width:14px;height:14px}
.resp-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px}
.resp-answer{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:9px 11px}
.resp-answer-q{font-family:var(--font-alt);font-size:9.5px;font-weight:600;color:var(--text-3);margin-bottom:3px;text-transform:uppercase;letter-spacing:.08em}
.resp-answer-a{font-size:12.5px;color:var(--text-1)}
.resp-answer-img{width:100%;max-height:200px;object-fit:contain;border-radius:var(--radius-sm);border:1px solid var(--border);margin-top:5px;cursor:pointer}
#toast{position:fixed;bottom:16px;right:16px;z-index:9999;display:flex;flex-direction:column;gap:5px}
.toast-item{padding:8px 13px;border-radius:var(--radius-sm);font-size:12.5px;font-weight:500;box-shadow:var(--shadow-md);animation:slideUp .2s ease;display:flex;align-items:center;gap:6px;min-width:180px}
.toast-item svg{width:12px;height:12px;stroke-width:2;flex-shrink:0;stroke:currentColor;fill:none}
.toast-success{background:#f0fdf4;color:var(--green);border:1px solid rgba(22,163,74,.25)}
.toast-error{background:#fef2f2;color:var(--red);border:1px solid rgba(220,38,38,.25)}
.toast-info{background:var(--surface);color:var(--text-1);border:1px solid var(--border-2)}
@keyframes slideUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.empty-state{text-align:center;padding:32px 20px;color:var(--text-2)}
.empty-state svg{width:30px;height:30px;stroke-width:1.2;color:var(--text-3);margin-bottom:8px;display:block;margin-left:auto;margin-right:auto}
.empty-state p{font-size:12.5px;margin-bottom:10px}

/* ── CHAT ── */
#chat-messages{height:380px;overflow-y:auto;background:var(--bg);border-radius:var(--radius-sm);padding:12px;margin-bottom:10px;display:flex;flex-direction:column;gap:8px}
.chat-msg{max-width:82%;padding:10px 13px;border-radius:12px;font-size:13px;line-height:1.6;word-break:break-word}
.chat-msg.user{align-self:flex-end;background:var(--accent);color:white;border-bottom-right-radius:3px}
.chat-msg.assistant{align-self:flex-start;background:var(--surface);border:1px solid var(--border);color:var(--text-1);border-bottom-left-radius:3px}
.chat-msg.assistant strong{color:var(--accent)}
.chat-msg pre{background:#1e1e2e;padding:9px 11px;border-radius:6px;overflow-x:auto;font-size:11.5px;color:#cdd6f4;margin:6px 0;white-space:pre-wrap;word-break:break-all}
.chat-msg code{font-family:monospace;background:rgba(0,0,0,.06);padding:1px 4px;border-radius:3px;font-size:12px}
.chat-msg pre code{background:none;padding:0}
.chat-msg ul,.chat-msg ol{padding-left:18px;margin:4px 0}
.chat-msg li{margin:2px 0}
.chat-typing{display:flex;gap:5px;align-items:center;padding:10px 13px;background:var(--surface);border:1px solid var(--border);border-radius:12px;border-bottom-left-radius:3px;width:fit-content;align-self:flex-start}
.typing-dot{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:tdot 1.2s infinite}
.typing-dot:nth-child(2){animation-delay:.2s}
.typing-dot:nth-child(3){animation-delay:.4s}
@keyframes tdot{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-5px);opacity:1}}
.chat-input-row{display:flex;gap:8px;align-items:flex-end}
#chat-input{flex:1;background:var(--bg);border:1px solid var(--border-2);border-radius:var(--radius-sm);padding:9px 11px;font-family:var(--font);font-size:13px;color:var(--text-1);resize:none;outline:none;transition:var(--t);min-height:44px;max-height:120px}
#chat-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
.chat-send-btn{height:44px;padding:0 16px;background:var(--accent);color:white;border:none;border-radius:var(--radius-sm);font-family:var(--font);font-weight:600;font-size:13px;cursor:pointer;transition:var(--t);display:flex;align-items:center;gap:5px;flex-shrink:0}
.chat-send-btn:hover{background:var(--accent-2)}
.chat-send-btn:disabled{opacity:.5;cursor:not-allowed}
.chat-send-btn svg{width:13px;height:13px;stroke-width:2;stroke:currentColor;fill:none}
.chat-provider-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}
.chat-context-pill{font-size:11px;background:var(--accent-soft);color:var(--accent);padding:3px 8px;border-radius:20px;font-weight:500}

/* ── FILL SCREEN ── */
#fill-screen{position:fixed;inset:0;z-index:1000;display:none;background:var(--bg);overflow-y:auto}
body.fill-only-mode #fill-screen{position:static;min-height:100vh}
.fill-wrap{max-width:600px;margin:0 auto;padding:32px 20px 80px}
.fill-header{display:flex;align-items:center;gap:10px;margin-bottom:20px}
.fill-form-title{font-family:var(--font-serif);font-size:22px;font-weight:400;margin-bottom:2px;color:var(--text-1)}
.fill-form-desc{font-size:12.5px;color:var(--text-2)}
.fill-progress{width:100%;height:3px;background:var(--surface-2);border-radius:2px;margin-bottom:20px;overflow:hidden}
.fill-progress-bar{height:100%;background:linear-gradient(90deg,var(--accent),var(--purple));border-radius:2px;transition:width .4s ease}
.fill-field{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:15px;margin-bottom:10px;box-shadow:var(--shadow)}
.fill-field-label{font-size:13px;font-weight:600;color:var(--text-1);margin-bottom:2px}
.fill-required{color:var(--red);font-size:11px;margin-left:3px}
.fill-field-hint{font-size:11.5px;color:var(--text-3);margin-bottom:7px}
.fill-input{width:100%;padding:9px 10px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);font-family:var(--font);font-size:13px;color:var(--text-1);outline:none;transition:var(--t)}
.fill-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
.fill-textarea{resize:vertical;min-height:80px}
.fill-radio-group,.fill-checkbox-group{display:flex;flex-direction:column;gap:5px;margin-top:5px}
.fill-radio-opt,.fill-checkbox-opt{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:var(--radius-sm);border:1px solid var(--border);cursor:pointer;transition:var(--t);font-size:12.5px;background:var(--bg);color:var(--text-1)}
.fill-radio-opt:hover,.fill-checkbox-opt:hover{border-color:var(--accent);background:var(--accent-soft)}
.fill-radio-opt input,.fill-checkbox-opt input{accent-color:var(--accent)}
.fill-scale{display:flex;gap:5px;flex-wrap:wrap;margin-top:6px}
.fill-scale-btn{width:36px;height:36px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--bg);font-size:12.5px;font-weight:500;color:var(--text-2);cursor:pointer;transition:var(--t)}
.fill-scale-btn:hover,.fill-scale-btn.selected{background:var(--accent);color:white;border-color:var(--accent)}
.file-upload-zone{border:2px dashed var(--border-2);border-radius:var(--radius-sm);padding:20px;text-align:center;cursor:pointer;transition:var(--t);background:var(--bg);margin-top:6px}
.file-upload-zone:hover,.file-upload-zone.dragover{border-color:var(--accent);background:var(--accent-soft)}
.file-upload-zone svg{width:24px;height:24px;color:var(--text-3);stroke-width:1.5;stroke:currentColor;fill:none;margin-bottom:6px}
.file-upload-zone p{font-size:12px;color:var(--text-3);margin:0}
.file-upload-zone .upload-hint{font-size:10.5px;color:var(--text-3);margin-top:3px}
.file-preview-wrap{margin-top:8px}
.image-preview-wrap{position:relative;display:inline-block}
.image-preview{max-width:100%;max-height:220px;border-radius:var(--radius-sm);border:1px solid var(--border);object-fit:contain;display:block}
.video-preview{max-width:100%;max-height:240px;border-radius:var(--radius-sm);border:1px solid var(--border);display:block}
.file-preview-doc{display:flex;align-items:center;gap:10px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px}
.file-preview-doc-icon{width:32px;height:32px;border-radius:7px;background:var(--accent-soft);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.file-preview-doc-icon svg{width:16px;height:16px;stroke:var(--accent);stroke-width:2;fill:none}
.file-preview-doc-name{font-size:12.5px;color:var(--text-1);font-weight:500;flex:1;word-break:break-all}
.file-preview-doc-size{font-size:10.5px;color:var(--text-3)}
.file-preview-remove{background:rgba(220,38,38,.85);border:none;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:white;flex-shrink:0}
.file-preview-remove svg{width:10px;height:10px;stroke:white;stroke-width:2.5;fill:none}
.image-preview-remove{position:absolute;top:4px;right:4px;background:rgba(220,38,38,.85);border:none;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:white}
.image-preview-remove svg{width:10px;height:10px;stroke:white;stroke-width:2.5;fill:none}
.upload-loading{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text-3);padding:10px}
.upload-loading .spinner{width:16px;height:16px;border:2px solid var(--border-2);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite}
.fill-submit-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:15px;margin-top:8px;box-shadow:var(--shadow)}
.fill-submit{width:100%;padding:11px;background:var(--accent);color:white;border:none;border-radius:var(--radius);font-family:var(--font);font-weight:600;font-size:13.5px;cursor:pointer;transition:var(--t);margin-top:11px;letter-spacing:.01em}
.fill-submit:hover{background:var(--accent-2);transform:translateY(-1px);box-shadow:0 5px 20px rgba(79,99,232,.25)}
.fill-submit:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
.fill-success{text-align:center;padding:50px 20px;display:none}
.fill-success-icon{width:52px;height:52px;border-radius:50%;background:var(--green-soft);border:2px solid var(--green);display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
.fill-success-icon svg{width:22px;height:22px;stroke-width:2;color:var(--green);stroke:currentColor;fill:none}
.fill-success-title{font-family:var(--font-serif);font-size:21px;margin-bottom:6px;color:var(--text-1)}
.fill-success-sub{font-size:13px;color:var(--text-2)}
.met-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border)}
.met-row:last-child{border-bottom:none}
.met-label{font-size:12px;color:var(--text-2)}
.met-val{font-family:var(--font-alt);font-size:16px;font-weight:700;color:var(--text-1);letter-spacing:-.02em}
.ai-provider-toggle{display:flex;gap:3px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:3px;margin-bottom:12px}
.ai-prov-btn{flex:1;padding:7px 10px;background:none;border:none;border-radius:6px;font-size:12px;font-weight:500;color:var(--text-2);cursor:pointer;transition:var(--t);display:flex;align-items:center;justify-content:center;gap:5px}
.ai-prov-btn.active{background:var(--surface);color:var(--text-1);box-shadow:var(--shadow)}
.ai-prov-btn svg{width:14px;height:14px}
.ai-key-section{transition:var(--t)}
.sql-hint{background:#1e1e2e;border-radius:var(--radius-sm);padding:12px;margin-top:8px}
.sql-hint pre{font-family:monospace;font-size:11px;color:#cdd6f4;line-height:1.6;white-space:pre-wrap;word-break:break-all}
.sql-hint-label{font-size:10px;color:#6c7086;font-family:var(--font-alt);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px}
.notif-section{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;margin-bottom:10px}
.notif-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0}
.notif-label{font-size:12.5px;color:var(--text-1)}
.notif-sub{font-size:11px;color:var(--text-3)}
.toggle-switch{width:36px;height:20px;background:var(--border-2);border-radius:10px;position:relative;cursor:pointer;transition:background .2s;border:none;flex-shrink:0}
.toggle-switch.on{background:var(--accent)}
.toggle-switch::after{content:'';position:absolute;width:14px;height:14px;background:white;border-radius:50%;top:3px;left:3px;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.toggle-switch.on::after{transform:translateX(16px)}
.search-results{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--surface);border:1px solid var(--border-2);border-radius:var(--radius);box-shadow:var(--shadow-md);z-index:500;max-height:280px;overflow-y:auto}
.search-result-item{display:flex;align-items:center;gap:9px;padding:9px 12px;cursor:pointer;transition:var(--t);border-bottom:1px solid var(--border)}
.search-result-item:last-child{border-bottom:none}
.search-result-item:hover{background:var(--surface-2)}
.search-result-type{font-size:9.5px;font-family:var(--font-alt);font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:2px 6px;border-radius:10px;flex-shrink:0}
.srt-form{background:var(--accent-soft);color:var(--accent)}
.srt-response{background:var(--green-soft);color:var(--green)}
.srt-org{background:var(--amber-soft);color:var(--amber)}
.search-result-title{font-size:12.5px;color:var(--text-1);font-weight:500}
.search-result-sub{font-size:11px;color:var(--text-3)}
.notif-channel-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;box-shadow:var(--shadow);margin-bottom:12px}
.notif-channel-header{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.notif-channel-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.notif-channel-icon svg{width:17px;height:17px;stroke-width:1.8;stroke:currentColor;fill:none}
.notif-channel-title{font-weight:600;font-size:13px;color:var(--text-1)}
.notif-channel-sub{font-size:11.5px;color:var(--text-3)}
.notif-status-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-left:auto}
.notif-status-dot.active{background:var(--green);box-shadow:0 0 0 3px var(--green-soft)}
.notif-status-dot.inactive{background:var(--text-3)}
.notif-config-body{border-top:1px solid var(--border);padding-top:12px}
.notif-hint{font-size:11px;color:var(--text-3);margin-top:4px;line-height:1.5}
.notif-hint a{color:var(--accent);text-decoration:underline}
.notif-test-row{display:flex;align-items:center;gap:8px;margin-top:10px}
.btn-test{padding:6px 12px;background:var(--surface-2);border:1px solid var(--border-2);border-radius:var(--radius-sm);font-size:12px;font-weight:500;color:var(--text-2);cursor:pointer;transition:var(--t);display:flex;align-items:center;gap:5px}
.btn-test:hover{border-color:var(--accent);color:var(--accent)}
.btn-test svg{width:12px;height:12px;stroke-width:2;stroke:currentColor;fill:none}
.notif-form-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.notif-form-row select{flex:1;padding:7px 9px;background:var(--bg);border:1px solid var(--border-2);border-radius:var(--radius-sm);font-size:12px;color:var(--text-1);outline:none}
.notif-log{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);max-height:180px;overflow-y:auto}
.notif-log-item{display:flex;align-items:center;gap:8px;padding:7px 10px;border-bottom:1px solid var(--border);font-size:12px}
.notif-log-item:last-child{border-bottom:none}
.notif-log-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.notif-log-dot.ok{background:var(--green)}
.notif-log-dot.fail{background:var(--red)}
.notif-log-dot.pending{background:var(--amber)}
.notif-log-msg{flex:1;color:var(--text-2)}
.notif-log-time{font-size:10.5px;color:var(--text-3);white-space:nowrap}

/* ── MOBILE BOTTOM TAB BAR ── */
.mobile-tab-bar{
  display:none;
  position:fixed;
  bottom:0;left:0;right:0;
  z-index:300;
  background:var(--surface);
  border-top:1px solid var(--border);
  padding:0 0 env(safe-area-inset-bottom,0);
  height:calc(56px + env(safe-area-inset-bottom,0));
}
.mobile-tabs{
  display:flex;
  align-items:stretch;
  height:56px;
}
.mobile-tab{
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:3px;
  background:none;
  border:none;
  color:var(--text-3);
  font-family:var(--font-alt);
  font-size:9px;
  font-weight:600;
  letter-spacing:.04em;
  text-transform:uppercase;
  cursor:pointer;
  transition:color var(--t);
  padding:6px 2px 4px;
  min-width:44px;
  -webkit-tap-highlight-color:transparent;
}
.mobile-tab svg{
  width:20px;height:20px;
  stroke-width:1.7;
  stroke:currentColor;
  fill:none;
  flex-shrink:0;
}
.mobile-tab.active{color:var(--accent);}
.mobile-tab-badge{
  position:absolute;
  top:-3px;right:calc(50% - 18px);
  width:7px;height:7px;
  border-radius:50%;
  background:var(--red);
  border:2px solid var(--surface);
}

/* ── MOBILE SIDEBAR DRAWER ── */
.sidebar-overlay{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.35);
  z-index:280;
  backdrop-filter:blur(2px);
  -webkit-backdrop-filter:blur(2px);
}
.sidebar-overlay.open{display:block;}

/* ── TABLET 1025–1280 ── */
@media(max-width:1280px){
  .grid-4{grid-template-columns:1fr 1fr;}
}

/* ── MEDIUM 1025–1024 ── */
@media(max-width:1024px){
  .icon-nav{display:none;}
  .sidebar{
    left:0;
    transform:translateX(-100%);
    transition:transform .28s cubic-bezier(.4,0,.2,1);
    z-index:290;
    box-shadow:4px 0 24px rgba(0,0,0,.12);
  }
  .sidebar.open{transform:translateX(0);}
  .main{margin-left:0;padding:16px;}
  .grid-4{grid-template-columns:1fr 1fr;}
}

/* ── MOBILE ≤700px ── */
@media(max-width:700px){
  /* Layout */
  .main{
    margin-left:0;
    padding:12px 12px calc(72px + env(safe-area-inset-bottom,0));
  }
  .cmd-bar{
    padding:8px 12px;
    margin:-12px -12px 14px;
    position:sticky;
    top:0;
  }
  .cmd-right .btn-accent span,
  .cmd-right .btn-accent svg+*{display:none;}
  .cmd-right .btn-accent{padding:7px 10px;}
  .cmd-right .btn-outline{display:none;}

  /* Grids collapse to single column */
  .grid-4,.grid-3,.grid-2{grid-template-columns:1fr;}

  /* Dashboard specific override: keep KPIs 2-up */
  #page-dashboard .grid-4{grid-template-columns:1fr 1fr;}

  /* Insight map + glance row stacks */
  #page-dashboard > div:nth-child(3){
    grid-template-columns:1fr!important;
  }

  /* Bottom tab bar visible */
  .mobile-tab-bar{display:block;}

  /* KPI cards */
  .kpi-card{padding:13px 13px 11px;}
  .kpi-value{font-size:24px;}
  .kpi-glow{width:50px;height:50px;}

  /* Cards */
  .card{padding:13px;}
  .card-sm{padding:11px;}

  /* Resp detail */
  .resp-detail-grid{grid-template-columns:1fr;}

  /* Command bar search */
  .cmd-wrap{max-width:none;flex:1;}
  .cmd-kbd{display:none;}

  /* Forms grid */
  #forms-grid{grid-template-columns:1fr;}

  /* Chat */
  #chat-messages{height:280px;}
  #chat-input{font-size:16px;} /* prevent iOS zoom */

  /* Fill screen */
  .fill-wrap{padding:20px 14px calc(80px + env(safe-area-inset-bottom,0));}

  /* Modal */
  .modal-overlay{
    padding:0;
    align-items:flex-end;
  }
  .modal{
    border-radius:var(--radius) var(--radius) 0 0;
    max-height:88vh;
  }
  .modal-sm,.modal-md{max-width:100%;}

  /* Page titles */
  .page-title{font-size:20px;}
  .page-header-row{flex-direction:column;gap:10px;}
  .page-header-row .btn{width:100%;justify-content:center;}

  /* Sidebar header btn */
  .sb-add{display:none;}

  /* Table horizontal scroll */
  .table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
  table{min-width:520px;}

  /* Settings */
  #page-settings .grid-2{grid-template-columns:1fr;}

  /* AI page */
  #page-ai .grid-2{grid-template-columns:1fr;}

  /* Metrics */
  .chart-container{height:160px;}

  /* Auth card */
  .auth-card{border-radius:0;border:none;min-height:100vh;padding:32px 20px;justify-content:flex-start;}
  #auth-screen{align-items:flex-start;padding-top:48px;}

  /* Toast bottom offset */
  #toast{bottom:calc(64px + env(safe-area-inset-bottom,0));right:12px;left:12px;}
  .toast-item{min-width:0;width:100%;}

  /* Focus card flex */
  .focus-card > div{flex-wrap:wrap;}

  /* Share modal platforms 2-up */
  .share-platforms{grid-template-columns:repeat(2,1fr);}

  /* Snap rows in dashboard */
  .snap-row{padding:7px 0;}

  /* Sidebar when open on mobile shouldn't overflow bottom */
  .sidebar{
    bottom:56px;
    bottom:calc(56px + env(safe-area-inset-bottom,0));
  }
}
  .insight-map {
  display: none;
}

/* ── VERY SMALL ≤360px ── */
@media(max-width:360px){
