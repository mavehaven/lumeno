function startFocusTimer(){
  clearInterval(focusInterval);if(!focusRunning)return;
  focusInterval=setInterval(()=>{
    if(focusSecs<=0){clearInterval(focusInterval);return;}
    focusSecs--;
    const h=Math.floor(focusSecs/3600),m=Math.floor((focusSecs%3600)/60),s=focusSecs%60;
    const disp=h>0?`${h}:${String(m).padStart(2,'0')}`:`${m}:${String(s).padStart(2,'0')}`;
    const el=document.getElementById('focus-time-display');if(el)el.textContent=disp;
    const gl=document.getElementById('gl-focus');if(gl)gl.textContent=h>0?`${h}h ${m}m left`:`${m}m left`;
  },1000);
}
