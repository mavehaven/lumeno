    const footerHTML = `
      <div class="pdf-footer">
        <span>LumenOS Intelligence Platform</span>
        <span>${esc(report.title)}</span>
        <span>${new Date().getFullYear()}</span>
      </div>`;
 
    // ── PAGE 1: Cover + KPIs + AI ──
    let page1 = `
      <div class="pdf-page">
        ${headerHTML}
        <div class="pdf-h1">Intelligence <em>Report</em></div>
        <div class="pdf-sub">${esc(report.title)}</div>`;
 
    if (snap.metrics) {
      page1 += `
        <div class="pdf-section-label">Key Metrics</div>
        <div class="pdf-kpi-row">
          <div class="pdf-kpi">
            <div class="pdf-kpi-label">Total Responses</div>
