    if(sparkCharts[id]){try{sparkCharts[id].destroy();}catch(e){}delete sparkCharts[id];}
    canvas.width=wrap.offsetWidth||68;canvas.height=wrap.offsetHeight||30;
    sparkCharts[id]=new Chart(canvas,{
      type:'line',
      data:{labels:data.map((_,i)=>i),datasets:[{data,borderColor:color,borderWidth:1.5,fill:true,backgroundColor:bg,pointRadius:0,tension:0.4}]},
      options:{responsive:false,animation:false,plugins:{legend:{display:false},tooltip:{enabled:false}},scales:{x:{display:false},y:{display:false}},layout:{padding:0}}
    });
  }
  const respData=buildCumulative(allResponses,8);const formsData=buildCumulative(allForms,8);
  makeSparkline('chart-forms',formsData.some(v=>v>0)?formsData:[1,1,2,2,3,4,4,allForms.length||0],'#16a34a','rgba(22,163,74,0.08)');
  makeSparkline('chart-resp',respData.some(v=>v>0)?respData:[1,1,2,2,3,4,4,allResponses.length||0],'#4f63e8','rgba(79,99,232,0.08)');
  makeSparkline('chart-score',[58,62,65,68,70,72,74,76],'#d97706','rgba(217,119,6,0.08)');
}
function buildCumulative(items,days){
  const out=[];const now=Date.now();let total=0;
  for(let i=days-1;i>=0;i--){
    const s=now-(i+1)*86400000,e=now-i*86400000;
    total+=items.filter(x=>{const t=new Date(x.created_at).getTime();return t>=s&&t<e;}).length;
    out.push(total);
  }
  return out;
}

