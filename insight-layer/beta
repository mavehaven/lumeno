async function saveFormEdit(id){
  const name=document.getElementById('nf-name').value.trim();
  const desc=document.getElementById('nf-desc').value.trim();
  const orgId=document.getElementById('nf-org').value;
  const slug=document.getElementById('nf-slug').value.trim().replace(/[^a-z0-9-]/gi,'').toLowerCase()||null;
  const oldFieldsJson=document.getElementById('nf-old-fields-json').value;
  if(!name){toast('Form name required','error');return;}
  const btn=document.getElementById('nf-submit-btn');btn.textContent='Saving…';
  try{
    const{error}=await sb.from('il_forms').update({name,description:desc||null,org_id:orgId||null,fields:formFields,share_slug:slug}).eq('id',id).select();
    if(error)throw error;
    const oldFields=JSON.parse(oldFieldsJson||'[]');
    const oldSL=oldFields.filter(f=>f.type==='scale').map(f=>f.label).sort().join(',');
    const newSL=formFields.filter(f=>f.type==='scale').map(f=>f.label).sort().join(',');
    if(oldSL!==newSL)await sb.rpc('recalculate_form_scores',{p_form_id:id}).catch(()=>{});
    closeModal('modal-new-form');toast('Form updated!','success');
    await loadForms();renderDashboard();
    if(document.getElementById('page-forms').classList.contains('active'))renderFormsPage();
  }catch(e){toast('Error: '+e.message,'error');}
  finally{btn.textContent='Save Changes';}
}
