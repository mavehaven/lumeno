  loadingStep.textContent = 'Building layout…';
 
  try {
    const pane = document.getElementById('pdf-render-pane');
 
    // ── Helper: score pill ──
    const scorePill = (s) => {
      if (s == null) return '<span class="pdf-score-pill pdf-score-grey">—</span>';
      if (s >= 70)   return `<span class="pdf-score-pill pdf-score-green">${s}</span>`;
      if (s >= 40)   return `<span class="pdf-score-pill pdf-score-amber">${s}</span>`;
      return               `<span class="pdf-score-pill pdf-score-red">${s}</span>`;
    };
 
    const headerHTML = `
      <div class="pdf-header">
        <div class="pdf-logo-text">Lumen<span style="color:#7c3aed">OS</span></div>
        <div class="pdf-report-title">
          <strong>${esc(report.title)}</strong><br>
          Generated ${new Date(snap.generatedAt).toLocaleString()}<br>
          By ${esc(snap.generatedBy)}
