// On load: if ?report= is in the URL, show the read-only report viewer
(function checkReportParam() {
  const params  = new URLSearchParams(location.search);
  const encoded = params.get('report');
  if (!encoded) return;

  // Wait for auth, then render
  const tryRender = setInterval(async () => {
    const { data: { session } } = await sb.auth.getSession();
    if (!session?.user) return; // keep waiting for login
    clearInterval(tryRender);

    let snapshot;
    try {
      snapshot = JSON.parse(decodeURIComponent(escape(atob(encoded))));
    } catch(e) {
      toast('Invalid or corrupted report link', 'error');
      return;
    }

    // Check expiry
    if (snapshot.expiresAt && new Date(snapshot.expiresAt) < new Date()) {
      toast('This report link has expired', 'error');
      return;
    }

    renderReportViewer(snapshot);
  }, 600);
})();

function renderReportViewer(snap) {
  // Inject a full-screen report overlay on top of the app
  const existing = document.getElementById('report-viewer-overlay');
  if (existing) existing.remove();

  const m = snap.metrics || {};
  const formRows = (snap.forms || []).map(f =>
    `<tr><td>${esc(f.name)}</td><td style="color:var(--text-2)">${esc(f.description || '—')}</td><td>${f.fieldCount}</td><td>${f.responseCount}</td></tr>`
  ).join('');

  const respRows = (snap.responses || []).slice(0, 200).map(r => {
    const s = r.score;
    const cls = s >= 70 ? 'badge-green' : s >= 40 ? 'badge-amber' : s != null ? 'badge-red' : 'badge-grey';
    return `<tr style="cursor:pointer" onclick="toggleRespAnswers(this,'${btoa(encodeURIComponent(JSON.stringify(r.answers||{})))}')">
      <td><strong>${esc(r.respondent)}</strong></td>
      <td style="color:var(--text-2)">${esc(r.form)}</td>
      <td>${s != null ? `<span class="badge ${cls}">${s}</span>` : '<span style="color:var(--text-3)">—</span>'}</td>
      <td style="color:var(--text-3)">${new Date(r.submittedAt).toLocaleString()}</td>
      <td><button class="btn-icon btn-icon-ghost" title="Expand"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="9 18 15 12 9 6"/></svg></button></td>
    </tr>`;
